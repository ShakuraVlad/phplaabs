{% extends "layout.html.twig" %}

{% block title %}Рецепты — Twig{% endblock %}

{% block content %}

{# --- Форма добавления --- #}
<section style="background:#fff; border-radius:10px; padding:1.5rem; box-shadow:0 1px 4px rgba(0,0,0,.08); margin-bottom:2rem;">
    <h2 style="margin-bottom:1rem; color:#1b4332;">➕ Добавить рецепт</h2>
    <form method="POST">
        <input type="hidden" name="action" value="add">
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:.8rem;">
            <label style="display:flex; flex-direction:column; gap:.3rem; font-size:.9rem;">
                Название
                <input type="text" name="name" required
                    style="padding:.5rem .7rem; border:1px solid #ccc; border-radius:6px; font-size:1rem;">
            </label>
            <label style="display:flex; flex-direction:column; gap:.3rem; font-size:.9rem;">
                Категория
                <input type="text" name="category" required
                    style="padding:.5rem .7rem; border:1px solid #ccc; border-radius:6px; font-size:1rem;">
            </label>
            <label style="display:flex; flex-direction:column; gap:.3rem; font-size:.9rem;">
                Время приготовления (мин)
                <input type="number" name="prep_time" min="1" required
                    style="padding:.5rem .7rem; border:1px solid #ccc; border-radius:6px; font-size:1rem;">
            </label>
            <label style="display:flex; flex-direction:column; gap:.3rem; font-size:.9rem;">
                Порции
                <input type="number" name="servings" min="1" value="2"
                    style="padding:.5rem .7rem; border:1px solid #ccc; border-radius:6px; font-size:1rem;">
            </label>
            <label style="display:flex; flex-direction:column; gap:.3rem; font-size:.9rem; grid-column:span 2;">
                Описание
                <textarea name="description" rows="2"
                    style="padding:.5rem .7rem; border:1px solid #ccc; border-radius:6px; font-size:1rem; resize:vertical;"></textarea>
            </label>
        </div>
        <button type="submit"
            style="margin-top:1rem; background:#1b4332; color:#fff; border:none; border-radius:6px;
                   padding:.6rem 1.4rem; font-size:1rem; cursor:pointer;">
            Добавить
        </button>
    </form>
</section>

{# --- Список рецептов --- #}
<section>
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem;">
        <h2 style="color:#1b4332;">📋 Все рецепты</h2>
        <span class="badge badge-mode">Twig</span>
    </div>

    {% if recipes is empty %}
        <p style="color:#888; text-align:center; padding:2rem;">Рецептов пока нет. Добавьте первый!</p>
    {% else %}
        <div style="display:grid; gap:1rem;">
        {% for recipe in recipes %}
            <div style="background:#fff; border-radius:10px; padding:1.2rem 1.5rem;
                        box-shadow:0 1px 4px rgba(0,0,0,.08); display:flex; align-items:flex-start; gap:1rem;">
                <div style="flex:1;">
                    <div style="display:flex; align-items:center; gap:.6rem; margin-bottom:.3rem;">
                        <strong style="font-size:1.05rem;">{{ recipe.name }}</strong>
                        <span class="badge">{{ recipe.category }}</span>
                    </div>
                    <p style="color:#666; font-size:.9rem; margin-bottom:.5rem;">
                        {{ recipe.description }}
                    </p>
                    <div style="font-size:.85rem; color:#555;">
                        ⏱ <strong>{{ recipe.prep_time | format_duration }}</strong>
                        &nbsp;·&nbsp;
                        🍽 {{ recipe.servings }} порц.
                    </div>
                </div>
                <form method="POST" style="flex-shrink:0;">
                    <input type="hidden" name="action" value="delete">
                    <input type="hidden" name="id" value="{{ recipe.id }}">
                    <button type="submit"
                        style="background:none; border:1px solid #e0e0e0; border-radius:6px;
                               padding:.4rem .8rem; cursor:pointer; color:#c0392b; font-size:.85rem;"
                        onclick="return confirm('Удалить рецепт?')">
                        🗑 Удалить
                    </button>
                </form>
            </div>
        {% endfor %}
        </div>
    {% endif %}
</section>

{% endblock %}
